{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(sudo systemctl:*)",
      "Bash(systemctl restart:*)",
      "Bash(systemctl stop:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Read(./.env)",
      "Read(./*.env)",
      "Read(/etc/k-invest.env)"
    ]
  }
}
