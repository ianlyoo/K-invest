# ══ MCP server ═══════════════════════════════════════════
# Bearer token required by MCP clients. Generate: openssl rand -hex 32
# MCP_AUTH_TOKEN=

# Public URL where this server is reachable from the internet
# (used for OAuth resource metadata and the DNS-rebinding allowlist).
# Local-only default:
MCP_PUBLIC_URL=http://127.0.0.1:8100

# OAuth 2.1 (optional, multi-client compatibility): when BOTH are set, the server
# also exposes a standard OAuth authorization-code flow so OAuth-based clients
# (ChatGPT, Claude, Cursor, ...) can connect by entering this ID/secret in their
# connector UI. The static MCP_AUTH_TOKEN keeps working for direct clients.
# Generate: python3 -c "import secrets; print(secrets.token_hex(8), secrets.token_urlsafe(32))"
# MCP_OAUTH_CLIENT_ID=k-invest-<hex>
# MCP_OAUTH_CLIENT_SECRET=<secret>
# MCP_OAUTH_TOKEN_TTL=3600   # access-token lifetime in seconds (optional)

# ══ Toss Securities ══════════════════════════════════════
# 발급: 토스증권 WTS 로그인 → 설정 → Open API
TOSS_CLIENT_ID=your_client_id_here
TOSS_CLIENT_SECRET=your_client_secret_here
# Multi-account (optional): JSON file, chmod 600
#   {"accounts": [{"label": "primary", "client_id": "...", "client_secret": "..."}]}
# TOSS_CREDS_FILE=/path/to/toss_creds.json

# ══ Korea Investment Securities (optional) ═══════════════
# 발급: https://apiportal.koreainvestment.com
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_CANO=              # 계좌번호 앞 8자리
# KIS_ACNT_PRDT_CD=01    # 계좌 상품 코드 (뒤 2자리)
# KIS_URL_BASE=https://openapi.koreainvestment.com:9443
# Or reuse an existing env file with APP_KEY/APP_SECRET/CANO/ACNT_PRDT_CD:
# KIS_ENV_FILE=/path/to/kis.env

# ══ SEC EDGAR (optional but recommended) ═════════════════
# SEC asks for a descriptive User-Agent with a contact email.
# SEC_USER_AGENT=k-invest/2.0 (you@example.com)

# ══ margin-ta technical analysis (optional) ══════════════
# Path to a margin-ta checkout. Unset = analyze_technical/get_entry_plan/
# scan_top_stocks return MARGIN_TA_NOT_CONFIGURED.
# MARGIN_TA_HOME=/path/to/margin-ta

# ══ Cache (optional) ═════════════════════════════════════
# Token cache directory (default: ~/.cache/k-invest)
# KINVEST_CACHE_DIR=
# TOSS_TOKEN_CACHE=   # Toss token cache override (margin-ta subprocess / direct TossClient use)
# KIS_TOKEN_CACHE=    # single-file override, KIS token
